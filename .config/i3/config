###############################################
## Setup
###############################################

set $display_keys terminal -t Help -c Help -s 100x30 -l -e shortcuts
set $app_launcher rofi -show drun
set $emoji_picker rofi-emoji
set $file_manager terminal -t Files -c Files -e nnn
set_from_resource $color cursorColor
set $terminal xfce4-terminal
set $mod Mod4
floating_modifier $mod
tiling_drag modifier titlebar
bindsym $mod+q kill

# ----------> Looks
for_window [class=".*"] border pixel 1
gaps inner 10
gaps outer 0
font pango:Inter 11
client.focused $color #000000 #ffffff $color $color

# ----------> reload the configuration file
bindsym $mod+Shift+c reload
# ----------> restart i3 inplace
bindsym $mod+Shift+r restart




###############################################
## Autostart
###############################################

# ----------> network applet <------------------
exec --no-startup-id nm-applet

# ----------> Init xterm <----------------------
exec_always --no-startup-id xrdb -merge ~/.Xresources

# ----------> Enable num lock <-----------------
exec_always --no-startup-id numlockx on

# ----------> arandr setting <------------------
exec_always --no-startup-id sh ~/.screenlayout/default.sh

# ----------> notification daemon <-------------
exec_always --no-startup-id killall -q dunst; dunst

# ----------> autostart applications <----------
exec --no-startup-id dex --autostart --environment i3

# ----------> lock screen <---------------------
exec --no-startup-id xss-lock --transfer-sleep-lock -- lock-screen

# ----------> set wallpaper <-------------------
exec --no-startup-id sleep 1; ~/.fehbg 

# ----------> autotiling feature <--------------
exec_always --no-startup-id autotiling

# ----------> ensure your D-Bus environment is aware of i3 session
exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY I3SOCK XDG_CURRENT_DESKTOP

# ----------> Keyboard Layout: US and Greek | Toggle: Alt+Shift
exec --no-startup-id setxkbmap -layout us,gr -option grp:alt_shift_toggle

# ----------> Status bar <----------------------
exec --no-startup-id polybar -r &

# ----------> Load xfsettingsd <----------------
exec --no-startup-id xfsettingsd

# ----------> Pipewire patch bay <--------------
exec --no-startup-id qpwgraph -m

# ----------> Authentication agent <------------
exec --no-startup-id /usr/libexec/lxqt-policykit-agent &

# ----------> Clipboard managerl <--------------
exec --no-startup-id xfce4-clipman

# ----------> Night Light <---------------------
exec --no-startup-id nightlight

# ----------> X Compositor <--------------------
exec --no-startup-id picom --config ~/.config/picom/picom.conf

# ----------> Firewall Applet <-----------------
exec --no-startup-id firewall-applet

# ----------> Welcome <--------------------------
exec --no-startup-id welcome startup

####################################################
## Use pactl to adjust volume in PulseAudio.
####################################################
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status




####################################
## Application Shortcuts
####################################

bindsym $mod+Return exec i3-sensible-terminal
bindsym $mod+w exec wallpapers
bindsym $mod+Shift+Return exec $file_manager
bindsym $mod+d exec --no-startup-id $app_launcher
bindsym $mod+e exec --no-startup-id $emoji_picker
bindsym $mod+b exec $display_keys
bindsym $mod+slash exec welcome
# bindsym $mod+x exec --no-startup-id rofi-power
# bindsym Print exec --no-startup-id rofi-grab



####################################
## Windows & Desktop Shortcuts
####################################

# ----------> change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# ----------> alternatively, you can use the cursor keys
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# ----------> move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# ----------> alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# ----------> split in horizontal orientation
# bindsym $mod+h split h

# ----------> split in vertical orientation
# bindsym $mod+v split v

# ----------> enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# ----------> change container layout (stacked, tabbed, toggle split)
# bindsym $mod+s layout stacking
# bindsym $mod+w layout tabbed
# bindsym $mod+e layout toggle split

# ----------> toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# ----------> change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# ----------> focus the parent container
bindsym $mod+a focus parent

# ----------> focus the child container
#bindsym $mod+d focus child

# ----------> Define workspaces names
set $ws1 "1"
set $ws2 "2"
