#!/usr/bin/env bash

# Define options with icons
options=" ’Ćæ \n ¾░£ē \n ¾░żä \n ¾░Ś╝ \n ’ĆŻ "
# Get selection from rofi
# Using uptime for the prompt as in your original script
chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "Uptime: $(uptime -p | sed 's/up //')" \
    -config ~/.config/rofi/power.rasi)

chosen=$(echo "$chosen" | xargs)

# Extract the keyword (lowercase) to send to the backend
case "$chosen" in
    "’Ćæ") sleep 0.5 && i3power shutdown ;;
    "¾░£ē") sleep 0.5 && i3power reboot   ;;
    "¾░żä") sleep 0.5 && i3power   ;;
    "¾░Ś╝") sleep 0.5 && i3power logout   ;;
    "’ĆŻ") sleep 0.5 && i3power lock     ;;
    *) echo "No match for: [$chosen]" ;; # Debugging
esac


echo "[$chosen]"
