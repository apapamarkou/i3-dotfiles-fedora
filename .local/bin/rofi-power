#!/usr/bin/env bash

# Define options with icons
options="ÔÄĎ  Shutdown\nůįúČ  Reboot\nůį§Ą  Suspend\nůįóľ  Logout\nÔÄ£  Lock"

# Get selection from rofi
# Using uptime for the prompt as in your original script
chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "Uptime: $(uptime -p | sed 's/up //')" \
    -config ~/.config/rofi/power.rasi)

# Extract the keyword (lowercase) to send to the backend
case "$chosen" in
    *Shutdown) i3power shutdown ;;
    *Reboot)   i3power reboot   ;;
    *Suspend)  i3power suspend  ;;
    *Logout)   i3power logout   ;;
    *Lock)     i3power lock     ;;
esac
