#!/usr/bin/env bash

options="рџ“ё Shot Full\nрџЄџ Shot Window\nвњ‚пёЏ Shot Selection\nрџЋҐ Record Full\nрџЋћпёЏ Record Window\nрџЋЇ Record Selection\nрџ›‘ Stop Recording"

chosen=$(echo -e "$options" | rofi -dmenu -i -p "Capture:")

case "$chosen" in
    "рџ“ё Shot Full")      prtscr shot-full ;;
    "рџЄџ Shot Window")    prtscr shot-window ;;
    "вњ‚пёЏ Shot Selection")  prtscr shot-sel ;;
    "рџЋҐ Record Full")    prtscr rec-full ;;
    "рџЋћпёЏ Record Window")  prtscr rec-window ;;
    "рџЋЇ Record Selection") prtscr rec-sel ;;
    "рџ›‘ Stop Recording")  prtscr stop ;;
esac
