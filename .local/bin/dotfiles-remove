#!/usr/bin/env bash

DOTFILES="$HOME/i3-dotfiles-fedora"
LIST="$DOTFILES/dotfile-paths"

mkdir -p "$DOTFILES"
touch "$LIST"

for item in "$@"; do
    abs="$(realpath "$item")"
    rel="${abs#$HOME/}"

    sed -i "\|^$rel$|d" "$LIST"

    rm -rf "$DOTFILES/$rel"

    notify-send "I3 Dotfiles" "\n Removed: $rel\n"
done

